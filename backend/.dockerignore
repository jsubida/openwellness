# Python caches and local envs
**/__pycache__
**/*.py[cod]
**/.venv
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/*.egg-info

# Tests are not needed in the image
**/tests

# Secrets / local env files
.env
.env.*

# Scheduler source is not built into the api image; keep only its pyproject
scheduler/src

# VCS / editor / OS noise
.git
.gitignore
**/.DS_Store
**/*.swp
