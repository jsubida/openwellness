# Copy to .env on the VM and fill in real values (never commit .env).
# Names map to backend/api/src/openwellness_api/config.py.

# Storage backend switch — selects which persistence backend the API and
# scheduler use. Defaults to couchbase-mongo (the settings below). Setting
# this to `postgres` requires POSTGRES_URL; no Postgres driver exists yet
# as of this phase, so this value is not wired to any repository.
STORAGE_BACKEND=couchbase-mongo

# Couchbase — external instance reachable via outbound access.
COUCHBASE_URL=
COUCHBASE_USERNAME=
COUCHBASE_PASSWORD=
COUCHBASE_BUCKET_NAME=

# Mongo — opserver publishes it on the VM host; reach it via host.docker.internal.
# The app user authenticates against the app DB itself, so authSource = <db> (NOT admin).
MONGO_URL=mongodb://<user>:<pass>@host.docker.internal:27017/?authSource=<db>
MONGO_DB=<db>

# Sync Gateway.
SYNC_GATEWAY_URL=

# Postgres — only required when STORAGE_BACKEND=postgres. No Postgres
# driver exists yet as of this phase; these are only read for the
# fail-fast startup check.
POSTGRES_URL=
POSTGRES_POOL_SIZE=5

# API metadata.
API_TITLE=OpenWellness API

# Default App-entity identifiers stamped by AppRepository.create_app
# (unlisted-link apps). Deployment-specific; leave empty to skip.
APP_STORE_ID=
APP_IOS_BUNDLE_ID=
APP_ONE_SIGNAL_APP_ID=

# Celery (scheduler) — broker + result backend. Defaults assume the redis
# service in docker-compose; names map to backend/scheduler/.../config.py.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
